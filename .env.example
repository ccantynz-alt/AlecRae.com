# =============================================================================
# AlecRae — Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values for your environment.
# Never commit the .env file to version control.
# =============================================================================

# -- App -------------------------------------------------------------------
NODE_ENV=development                      # development | staging | production
PORT=3001                                # API server port

# -- Database --------------------------------------------------------------
# Local PostgreSQL:
# DATABASE_URL=postgres://alecrae:dev_password@localhost:5432/alecrae
# Neon Postgres (managed serverless):
DATABASE_URL=postgresql://user:pass@ep-xxx-yyy-123456.us-east-2.aws.neon.tech/dbname?sslmode=require
REDIS_URL=redis://localhost:6379

# -- ClickHouse (Analytics) ------------------------------------------------
CLICKHOUSE_URL=http://localhost:8123
CLICKHOUSE_USER=alecrae
CLICKHOUSE_PASSWORD=dev_password

# -- Search (Meilisearch) -------------------------------------------------
MEILI_URL=http://localhost:7700
MEILI_MASTER_KEY=dev_master_key
MEILISEARCH_URL=http://localhost:7700      # Alias used by @alecrae/shared
MEILISEARCH_API_KEY=dev_master_key         # Alias used by @alecrae/shared

# -- Web App ---------------------------------------------------------------
NEXT_PUBLIC_API_URL=http://localhost:3001  # API URL for the web frontend

# -- Auth ------------------------------------------------------------------
JWT_SECRET=change_me_in_production        # Min 32 characters in production
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:3002
# Founder/staff full-access accounts (no billing, enterprise tier). The founder
# email is built in; add extra owners here, comma-separated.
OWNER_EMAILS=

# -- Google OAuth ----------------------------------------------------------
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_AUTH_REDIRECT_URI=https://api.alecrae.com/v1/auth/callback/google
GOOGLE_REDIRECT_URI=https://api.alecrae.com/v1/connect/callback/gmail

# -- Microsoft OAuth -------------------------------------------------------
MICROSOFT_CLIENT_ID=your-microsoft-client-id
MICROSOFT_CLIENT_SECRET=your-microsoft-client-secret
MICROSOFT_REDIRECT_URI=https://api.alecrae.com/v1/connect/callback/outlook

# -- DNS Auto-Configuration ------------------------------------------------
DNS_MX_PRIMARY=mx1.alecrae.com           # Primary MX server hostname
DNS_MX_SECONDARY=mx2.alecrae.com         # Secondary MX server hostname
DNS_SPF_INCLUDE=_spf.alecrae.com          # SPF include domain
DNS_DMARC_RUA=dmarc@alecrae.com          # DMARC aggregate report address
DNS_BOUNCE_DOMAIN=bounce.alecrae.com     # Return-path / bounce CNAME target
DKIM_KEY_ROTATION_DAYS=90                # Days before DKIM key rotation warning

# -- MTA (Mail Transfer Agent) --------------------------------------------
MTA_HOSTNAME=mail.alecrae.com            # Public SMTP hostname
MTA_QUEUE_NAME=alecrae-outbound
MTA_WORKER_CONCURRENCY=10
DKIM_SELECTOR=default

# -- Reputation Monitoring (Google Postmaster Tools + Microsoft SNDS) -----
# GOOGLE_POSTMASTER_VERIFICATION_TOKEN=  # From postmaster.google.com -> Add domain -> Verify via TXT record
# GOOGLE_POSTMASTER_SERVICE_ACCOUNT_JSON=  # Full service-account key JSON as a single-line string (scope: postmaster / postmaster.readonly)
# GOOGLE_POSTMASTER_DOMAIN=alecrae.com     # Domain to poll in addition to any verified domains in the DB
# SNDS_ACCESS_TOKEN=                       # Microsoft SNDS automated-data-access token
# SLACK_WEBHOOK_URL=                       # Incoming webhook for [REPUTATION]/[COMPLIANCE] alerts

# -- Vapron (Platform — email, AI gateway, object storage, deploy) ---------
VAPRON_API_KEY=vpk_your_api_key_here
VAPRON_BASE_URL=https://api.vapron.ai/api/trpc
VAPRON_WELCOME_EMAIL=true

# -- AI (optional) ---------------------------------------------------------
# ANTHROPIC_API_KEY=                      # Anthropic API key for Claude
# AI_MODEL_ID=claude-sonnet-4-20250514

# -- Monitoring / OpenTelemetry (optional) ---------------------------------
# OTEL_ENABLED=true                       # Set to "true" to enable OpenTelemetry
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318  # OTLP/HTTP collector endpoint
# OTEL_SERVICE_NAME=                      # Override auto-detected service name
# GRAFANA_URL=http://localhost:3002

# -- Payment / Billing (optional) -----------------------------------------
# STRIPE_SECRET_KEY=                      # sk_test_... or sk_live_...
# STRIPE_WEBHOOK_SECRET=                  # whsec_...
# STRIPE_PRICE_STARTER=price_starter      # Stripe Price ID for Starter plan
# STRIPE_PRICE_PROFESSIONAL=price_professional  # Stripe Price ID for Professional plan
# STRIPE_PRICE_ENTERPRISE=price_enterprise      # Stripe Price ID for Enterprise plan

# -- Docker Compose --------------------------------------------------------
POSTGRES_PASSWORD=dev_password
