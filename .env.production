# Vienna (Emailed) — Production Environment
# Cloudflare + Neon + Upstash Redis
# Domain: 48co.ai
# Copy to .env and fill in real values

# ─── App ──────────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3001
API_URL=https://api.48co.ai
WEB_URL=https://mail.48co.ai
LANDING_URL=https://48co.ai
ADMIN_URL=https://admin.48co.ai

# ─── Database (Neon Serverless PostgreSQL) ────────────────────────────────────
# Get from: https://console.neon.tech → your project → Connection Details
DATABASE_URL=postgresql://neondb_owner:YOUR_PASSWORD@ep-XXXXX-XXXXX-123456.us-east-2.aws.neon.tech/neondb?sslmode=require

# ─── Redis (Upstash — serverless Redis for Cloudflare Workers) ────────────────
# Get from: https://console.upstash.com → Create Database → REST URL
# Upstash is recommended because Cloudflare Workers can't use raw TCP Redis
REDIS_URL=rediss://default:YOUR_TOKEN@YOUR_ENDPOINT.upstash.io:6379
UPSTASH_REDIS_URL=https://YOUR_ENDPOINT.upstash.io
UPSTASH_REDIS_TOKEN=YOUR_TOKEN

# ─── Search (Meilisearch Cloud) ──────────────────────────────────────────────
# Get from: https://cloud.meilisearch.com → Create Project
MEILISEARCH_URL=https://ms-XXXXX.meilisearch.io
MEILISEARCH_API_KEY=YOUR_MEILISEARCH_KEY
MEILI_URL=https://ms-XXXXX.meilisearch.io
MEILI_MASTER_KEY=YOUR_MEILISEARCH_KEY

# ─── Storage (Cloudflare R2 — S3-compatible, zero egress fees) ────────────────
# Get from: Cloudflare Dashboard → R2 → Create Bucket → "vienna-attachments"
S3_ENDPOINT=https://YOUR_ACCOUNT_ID.r2.cloudflarestorage.com
S3_ACCESS_KEY=YOUR_R2_ACCESS_KEY
S3_SECRET_KEY=YOUR_R2_SECRET_KEY
S3_BUCKET=vienna-attachments

# ─── Auth ─────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 48
JWT_SECRET=GENERATE_A_STRONG_SECRET_HERE_MIN_32_CHARS
JWT_ISSUER=https://api.48co.ai
CORS_ORIGINS=https://48co.ai,https://mail.48co.ai,https://admin.48co.ai,https://api.48co.ai

# ─── DNS / Email Infrastructure ───────────────────────────────────────────────
# These define what DNS records are generated for customer domains
DNS_MX_PRIMARY=mx1.48co.ai
DNS_MX_SECONDARY=mx2.48co.ai
DNS_SPF_INCLUDE=spf.48co.ai
DNS_DMARC_RUA=dmarc-reports@48co.ai
DNS_BOUNCE_DOMAIN=bounce.48co.ai
DKIM_KEY_ROTATION_DAYS=90

# ─── SMTP / MTA ──────────────────────────────────────────────────────────────
SMTP_PORT=25
SMTP_HOST=0.0.0.0
SMTP_HOSTNAME=smtp.48co.ai
MTA_QUEUE_NAME=emailed:outbound
MTA_WORKER_CONCURRENCY=20
MTA_HOSTNAME=smtp.48co.ai

# ─── Relay Provider (pick ONE) ────────────────────────────────────────────────
# Option A: Amazon SES (recommended for high volume)
RELAY_PROVIDER=ses
SES_SMTP_HOST=email-smtp.us-east-1.amazonaws.com
SES_SMTP_PORT=587
SES_SMTP_USERNAME=YOUR_SES_SMTP_USERNAME
SES_SMTP_PASSWORD=YOUR_SES_SMTP_PASSWORD
SES_REGION=us-east-1

# Option B: MailChannels (simpler setup, good deliverability)
# RELAY_PROVIDER=mailchannels
# MAILCHANNELS_API_KEY=YOUR_MAILCHANNELS_KEY

# ─── AI ───────────────────────────────────────────────────────────────────────
# Required for: Grammar Agent, Voice Drafting, Dictation Polish, Translation, Smart Inbox AI
ANTHROPIC_API_KEY=YOUR_ANTHROPIC_API_KEY
AI_MODEL_ID=claude-haiku-4-5-20251001

# Optional: for Whisper transcription (dictation feature)
OPENAI_API_KEY=YOUR_OPENAI_API_KEY

# ─── Stripe Billing ──────────────────────────────────────────────────────────
# Get from: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_live_YOUR_STRIPE_KEY
STRIPE_WEBHOOK_SECRET=whsec_YOUR_WEBHOOK_SECRET
# Create products/prices in Stripe Dashboard, then paste IDs here:
STRIPE_PRICE_STARTER=price_YOUR_STARTER_PRICE_ID
STRIPE_PRICE_PROFESSIONAL=price_YOUR_PROFESSIONAL_PRICE_ID
STRIPE_PRICE_ENTERPRISE=price_YOUR_ENTERPRISE_PRICE_ID

# ─── Monitoring (OpenTelemetry) ───────────────────────────────────────────────
OTEL_ENABLED=true
OTEL_EXPORTER_OTLP_ENDPOINT=https://otel.48co.ai
OTEL_SERVICE_NAME=vienna-api

# ─── OAuth (Gmail + Outlook account connection) ──────────────────────────────
# Google: https://console.cloud.google.com → APIs & Services → Credentials
GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID
GOOGLE_CLIENT_SECRET=YOUR_GOOGLE_CLIENT_SECRET
GOOGLE_REDIRECT_URI=https://api.48co.ai/v1/connect/callback/gmail

# Microsoft: https://portal.azure.com → App registrations → New registration
MICROSOFT_CLIENT_ID=YOUR_MICROSOFT_CLIENT_ID
MICROSOFT_CLIENT_SECRET=YOUR_MICROSOFT_CLIENT_SECRET
MICROSOFT_REDIRECT_URI=https://api.48co.ai/v1/connect/callback/outlook

# ─── Cloudflare ───────────────────────────────────────────────────────────────
CLOUDFLARE_ACCOUNT_ID=YOUR_CF_ACCOUNT_ID
CLOUDFLARE_API_TOKEN=YOUR_CF_API_TOKEN
CLOUDFLARE_ZONE_ID=YOUR_48CO_AI_ZONE_ID
