{
  "expo": {
    "name": "Rae",
    "slug": "rae",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "rae",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0f172a"
    },
    "ios": {
      "bundleIdentifier": "com.rae.app",
      "buildNumber": "1",
      "supportsTablet": true,
      "associatedDomains": [
        "applinks:rae.com",
        "applinks:alecrae.com",
        "applinks:mail.alecrae.com"
      ],
      "infoPlist": {
        "NSFaceIDUsageDescription": "Rae uses Face ID to quickly unlock your encrypted email.",
        "NSMicrophoneUsageDescription": "Rae uses your microphone for voice dictation and voice message replies.",
        "NSCameraUsageDescription": "Rae uses your camera to attach photos and videos to emails.",
        "NSContactsUsageDescription": "Rae accesses your contacts for email auto-complete and to enrich sender profiles.",
        "NSCalendarUsageDescription": "Rae accesses your calendar to schedule meetings and show your availability when composing.",
        "NSPhotoLibraryUsageDescription": "Rae accesses your photo library to attach images to emails.",
        "NSPhotoLibraryAddUsageDescription": "Rae saves email attachments to your photo library.",
        "NSSpeechRecognitionUsageDescription": "Rae uses speech recognition to transcribe your voice messages.",
        "NSUserTrackingUsageDescription": "Rae does not track you across other apps or websites.",
        "LSApplicationQueriesSchemes": ["mailto"]
      },
      "privacyManifests": {
        "NSPrivacyTracking": false,
        "NSPrivacyTrackingDomains": [],
        "NSPrivacyCollectedDataTypes": [],
        "NSPrivacyAccessedAPITypes": [
          {
            "NSPrivacyAccessedAPIType": "NSPrivacyAccessedAPICategoryFileTimestampAPIs",
            "NSPrivacyAccessedAPITypeReasons": ["C617.1"]
          },
          {
            "NSPrivacyAccessedAPIType": "NSPrivacyAccessedAPICategorySystemBootTime",
            "NSPrivacyAccessedAPITypeReasons": ["35F9.1"]
          },
          {
            "NSPrivacyAccessedAPIType": "NSPrivacyAccessedAPICategoryDiskSpace",
            "NSPrivacyAccessedAPITypeReasons": ["E174.1"]
          },
          {
            "NSPrivacyAccessedAPIType": "NSPrivacyAccessedAPICategoryUserDefaults",
            "NSPrivacyAccessedAPITypeReasons": ["CA92.1"]
          }
        ]
      }
    },
    "android": {
      "package": "com.rae.app",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0f172a"
      },
      "permissions": [
        "android.permission.INTERNET",
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.VIBRATE",
        "android.permission.WAKE_LOCK",
        "android.permission.USE_BIOMETRIC",
        "android.permission.USE_FINGERPRINT",
        "android.permission.RECORD_AUDIO",
        "android.permission.CAMERA",
        "android.permission.READ_CONTACTS",
        "android.permission.READ_CALENDAR",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.POST_NOTIFICATIONS"
      ],
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            { "scheme": "https", "host": "rae.com" },
            { "scheme": "https", "host": "alecrae.com" },
            { "scheme": "https", "host": "mail.alecrae.com" },
            { "scheme": "mailto" }
          ],
          "category": ["BROWSABLE", "DEFAULT"]
        }
      ]
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "Rae uses Face ID to quickly unlock your encrypted email."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#3b82f6",
          "defaultChannel": "default"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "eas": {
        "projectId": "rae-app"
      },
      "apiUrl": "https://api.alecrae.com"
    },
    "owner": "rae",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/rae-app"
    }
  }
}
