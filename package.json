{
  "name": "alecrae",
  "version": "0.1.0",
  "private": true,
  "description": "AI-Native Email Infrastructure Platform",
  "workspaces": [
    "apps/*",
    "services/*",
    "packages/*",
    "infrastructure/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "build:api": "echo \"No build step: Bun runs the API directly from TypeScript\"",
    "start": "bun run apps/api/src/index.ts",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "clean": "turbo run clean",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "preflight": "bun run scripts/preflight.ts",
    "docs:check": "bun run scripts/check-docs.ts",
    "docs:fix": "bun run scripts/check-docs.ts --fix",
    "db:migrate": "bun run packages/db/src/migrate.ts",
    "db:seed": "bun run packages/db/src/seed.ts",
    "db:generate": "bun run --cwd packages/db db:generate",
    "db:push": "bun run --cwd packages/db db:push",
    "db:studio": "bun run --cwd packages/db db:studio",
    "db:check-drift": "bash scripts/check-schema-drift.sh",
    "load-test:smoke": "k6 run load-tests/smoke.js",
    "load-test:auth": "k6 run load-tests/scenarios/auth.js",
    "load-test:inbox": "k6 run load-tests/scenarios/inbox.js",
    "load-test:search": "k6 run load-tests/scenarios/search.js",
    "load-test:compose-send": "k6 run load-tests/scenarios/compose-send.js",
    "load-test:read-heavy": "k6 run load-tests/scenarios/read-heavy.js",
    "load-test:full": "k6 run load-tests/scenarios/full-suite.js"
  },
  "dependencies": {
    "meilisearch": "^0.44.0",
    "next": "^15.1.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^22.0.0",
    "bun-types": "^1.3.11",
    "eslint": "^9.0.0",
    "prettier": "^3.4.0",
    "turbo": "^2.3.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.58.1",
    "vitest": "^2.1.0"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "packageManager": "bun@1.2.0"
}
